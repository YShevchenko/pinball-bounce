{"screenId":"4daee29a350d4006b1d4fcb573f78470","projectId":"6679960351145125367","htmlContent":"<html class=\"dark\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&amp;family=Manrope:wght@200;300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n    tailwind.config = {\n      darkMode: \"class\",\n      theme: {\n        extend: {\n          colors: {\n            \"tertiary-fixed-dim\": \"#00ec90\",\n            \"on-primary-fixed\": \"#003f43\",\n            \"on-tertiary\": \"#00643a\",\n            \"outline\": \"#76747b\",\n            \"on-tertiary-fixed-variant\": \"#00653b\",\n            \"error-container\": \"#9f0519\",\n            \"tertiary-fixed\": \"#00fc9a\",\n            \"inverse-primary\": \"#006a71\",\n            \"on-error-container\": \"#ffa8a3\",\n            \"on-secondary-fixed-variant\": \"#950085\",\n            \"surface-container-high\": \"#1f1f26\",\n            \"primary-dim\": \"#00deec\",\n            \"outline-variant\": \"#48474d\",\n            \"surface-tint\": \"#8ff5ff\",\n            \"primary-fixed-dim\": \"#00deec\",\n            \"background\": \"#0e0e13\",\n            \"primary-container\": \"#00eefc\",\n            \"inverse-surface\": \"#fcf8ff\",\n            \"surface-variant\": \"#25252d\",\n            \"tertiary\": \"#a1ffc2\",\n            \"secondary-container\": \"#ad009b\",\n            \"on-primary-container\": \"#005359\",\n            \"on-surface-variant\": \"#acaab1\",\n            \"secondary-dim\": \"#ff59e3\",\n            \"surface-container-low\": \"#131319\",\n            \"on-primary-fixed-variant\": \"#005e64\",\n            \"on-primary\": \"#005d63\",\n            \"surface-container\": \"#19191f\",\n            \"on-tertiary-fixed\": \"#004627\",\n            \"surface-bright\": \"#2c2b33\",\n            \"on-error\": \"#490006\",\n            \"surface\": \"#0e0e13\",\n            \"on-surface\": \"#f9f5fd\",\n            \"tertiary-container\": \"#00fc9a\",\n            \"primary-fixed\": \"#00eefc\",\n            \"on-secondary\": \"#42003a\",\n            \"secondary-fixed-dim\": \"#ffa8e7\",\n            \"error\": \"#ff716c\",\n            \"error-dim\": \"#d7383b\",\n            \"secondary-fixed\": \"#ffbeeb\",\n            \"on-secondary-container\": \"#fff5f8\",\n            \"tertiary-dim\": \"#00ec90\",\n            \"surface-dim\": \"#0e0e13\",\n            \"surface-container-highest\": \"#25252d\",\n            \"surface-container-lowest\": \"#000000\",\n            \"on-background\": \"#f9f5fd\",\n            \"on-secondary-fixed\": \"#640059\",\n            \"secondary\": \"#ff59e3\",\n            \"primary\": \"#8ff5ff\",\n            \"on-tertiary-container\": \"#005b34\",\n            \"inverse-on-surface\": \"#55545b\"\n          },\n          fontFamily: {\n            \"headline\": [\"Space Grotesk\"],\n            \"body\": [\"Manrope\"],\n            \"label\": [\"Space Grotesk\"]\n          },\n          borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n        },\n      },\n    }\n  </script>\n<style>\n    .material-symbols-outlined {\n      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n    }\n    .neon-glow-primary {\n      box-shadow: 0 0 20px rgba(143, 245, 255, 0.4);\n    }\n    .neon-text-glow {\n      text-shadow: 0 0 12px rgba(0, 238, 252, 0.8);\n    }\n    .asymmetric-clip {\n      clip-path: polygon(0 0, 100% 0, 100% 90%, 95% 100%, 0 100%);\n    }\n  </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface font-body selection:bg-primary selection:text-on-primary-fixed overflow-hidden\">\n<!-- BACKGROUND GAMEPLAY HUD (Blurred/Overlayed) -->\n<div class=\"fixed inset-0 z-0\">\n<!-- Simulated Gameplay Canvas -->\n<div class=\"absolute inset-0 bg-[url('image-gameplay-bg')] bg-cover bg-center grayscale opacity-30\" data-alt=\"Cyberpunk city street at night with neon lights reflected in rain puddles, low angle perspective with sharp lines\"></div>\n<!-- TopAppBar from JSON Authority -->\n<header class=\"w-full top-0 sticky flex items-center justify-between px-6 py-4 w-full bg-transparent z-10\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-cyan-400\">menu</span>\n</div>\n<div class=\"text-2xl font-black text-cyan-400 drop-shadow-[0_0_8px_rgba(0,240,255,0.8)] font-['Space_Grotesk'] font-bold tracking-tighter uppercase\">VICTORY</div>\n<div class=\"w-6\"></div> <!-- Spacer for centering -->\n</header>\n<!-- Gameplay UI Elements (Distant/Blurred) -->\n<main class=\"p-8 space-y-8 blur-sm\">\n<div class=\"flex justify-between items-start\">\n<div class=\"space-y-2\">\n<div class=\"w-32 h-2 bg-surface-container-lowest rounded-full overflow-hidden\">\n<div class=\"w-2/3 h-full bg-primary neon-glow-primary\"></div>\n</div>\n<div class=\"font-headline text-primary text-xl uppercase tracking-widest\">HP 65%</div>\n</div>\n<div class=\"text-right\">\n<div class=\"font-headline text-4xl text-on-surface\">1,450</div>\n<div class=\"font-label text-xs text-on-surface-variant uppercase tracking-widest\">Current Score</div>\n</div>\n</div>\n<div class=\"grid grid-cols-2 gap-4\">\n<div class=\"h-48 bg-surface-container-low rounded-xl\"></div>\n<div class=\"h-48 bg-surface-container-low rounded-xl\"></div>\n</div>\n</main>\n</div>\n<!-- VICTORY MODAL OVERLAY -->\n<div class=\"fixed inset-0 z-50 flex items-center justify-center p-6 bg-surface-container-lowest/90 backdrop-blur-md\">\n<!-- Central Popup Card -->\n<div class=\"w-full max-w-sm bg-surface-container-high rounded-xl relative overflow-hidden flex flex-col items-center pt-12 pb-8 px-8 border border-outline-variant/20 shadow-[0_0_64px_rgba(143,245,255,0.1)]\">\n<!-- Aesthetic Background Elements -->\n<div class=\"absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-3xl -mr-16 -mt-16\"></div>\n<div class=\"absolute bottom-0 left-0 w-32 h-32 bg-secondary/5 rounded-full blur-3xl -ml-16 -mb-16\"></div>\n<!-- Victory Icon -->\n<div class=\"mb-6 relative\">\n<div class=\"absolute inset-0 bg-primary/20 blur-xl rounded-full\"></div>\n<div class=\"relative w-24 h-24 rounded-full border-2 border-primary flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-primary text-5xl\" style=\"font-variation-settings: 'FILL' 1;\">workspace_premium</span>\n</div>\n</div>\n<!-- Heading -->\n<h1 class=\"font-headline text-4xl font-black text-primary neon-text-glow text-center uppercase tracking-tighter leading-none mb-2\">\n        LEVEL COMPLETE!\n      </h1>\n<p class=\"font-body text-on-surface-variant text-center text-sm mb-10 tracking-wide\">\n        YOU'VE BREACHED THE SECTOR DATA CORE\n      </p>\n<!-- Stats Grid (Bento Style) -->\n<div class=\"w-full grid grid-cols-2 gap-3 mb-10\">\n<div class=\"bg-surface-container-lowest p-4 rounded-lg flex flex-col items-center border border-outline-variant/10\">\n<span class=\"font-label text-[10px] text-primary uppercase tracking-[0.2em] mb-1\">XP Gained</span>\n<span class=\"font-headline text-xl text-on-surface\">+2,400</span>\n</div>\n<div class=\"bg-surface-container-lowest p-4 rounded-lg flex flex-col items-center border border-outline-variant/10\">\n<span class=\"font-label text-[10px] text-tertiary uppercase tracking-[0.2em] mb-1\">Time</span>\n<span class=\"font-headline text-xl text-on-surface\">02:45</span>\n</div>\n</div>\n<!-- Action Buttons -->\n<div class=\"w-full space-y-4\">\n<!-- Primary Button -->\n<button class=\"w-full bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed font-headline font-extrabold text-xl py-5 rounded-md neon-glow-primary active:scale-95 transition-all flex items-center justify-center gap-2 group\">\n          NEXT LEVEL\n          <span class=\"material-symbols-outlined font-bold group-hover:translate-x-1 transition-transform\">chevron_right</span>\n</button>\n<!-- Secondary Button (Ad Reward) -->\n<button class=\"w-full bg-surface-container-highest border border-outline-variant/30 text-secondary font-headline font-bold text-sm py-4 rounded-md flex items-center justify-center gap-2 active:scale-95 transition-all hover:bg-white/5\">\n<span class=\"material-symbols-outlined text-lg\" style=\"font-variation-settings: 'FILL' 1;\">play_circle</span>\n          WATCH AD FOR +500 COINS\n        </button>\n</div>\n<!-- Footer Link -->\n<button class=\"mt-8 font-label text-xs text-outline tracking-[0.3em] uppercase hover:text-on-surface transition-colors\">\n        Main Menu\n      </button>\n</div>\n<!-- Level Up Particle Simulation (Decorative) -->\n<div class=\"absolute bottom-10 left-10 w-2 h-2 bg-primary rounded-full blur-[2px] opacity-40\"></div>\n<div class=\"absolute top-20 right-20 w-1 h-1 bg-secondary rounded-full blur-[1px] opacity-40\"></div>\n<div class=\"absolute bottom-40 right-10 w-3 h-3 bg-tertiary rounded-full blur-[4px] opacity-20\"></div>\n</div>\n<!-- BottomNavBar Authority - Suppressed for Modal Focus as per UX Goal -->\n<!-- We follow \"Automatic Suppression\" rule: Modal implies a temporary focused journey. -->\n</body></html>"}
