{"screenId":"b1d5202e8bef4259a00d1a462e2ebd3f","projectId":"6679960351145125367","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>NEON PULSE - HUD</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;700;900&amp;family=Manrope:wght@300;400;600&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"on-primary\": \"#005d63\",\n                        \"surface-dim\": \"#0e0e13\",\n                        \"surface\": \"#0e0e13\",\n                        \"tertiary-fixed-dim\": \"#00ec90\",\n                        \"outline-variant\": \"#48474d\",\n                        \"on-surface-variant\": \"#acaab1\",\n                        \"tertiary-fixed\": \"#00fc9a\",\n                        \"tertiary\": \"#a1ffc2\",\n                        \"on-primary-fixed-variant\": \"#005e64\",\n                        \"on-primary-fixed\": \"#003f43\",\n                        \"primary-container\": \"#00eefc\",\n                        \"on-error-container\": \"#ffa8a3\",\n                        \"surface-container-low\": \"#131319\",\n                        \"primary\": \"#8ff5ff\",\n                        \"on-error\": \"#490006\",\n                        \"on-secondary-container\": \"#fff5f8\",\n                        \"background\": \"#0e0e13\",\n                        \"secondary-dim\": \"#ff59e3\",\n                        \"inverse-primary\": \"#006a71\",\n                        \"surface-container\": \"#19191f\",\n                        \"error-dim\": \"#d7383b\",\n                        \"surface-container-highest\": \"#25252d\",\n                        \"tertiary-container\": \"#00fc9a\",\n                        \"surface-tint\": \"#8ff5ff\",\n                        \"on-tertiary-container\": \"#005b34\",\n                        \"tertiary-dim\": \"#00ec90\",\n                        \"on-secondary\": \"#42003a\",\n                        \"secondary-container\": \"#ad009b\",\n                        \"secondary\": \"#ff59e3\",\n                        \"secondary-fixed-dim\": \"#ffa8e7\",\n                        \"surface-container-high\": \"#1f1f26\",\n                        \"inverse-surface\": \"#fcf8ff\",\n                        \"on-tertiary\": \"#00643a\",\n                        \"inverse-on-surface\": \"#55545b\",\n                        \"error-container\": \"#9f0519\",\n                        \"error\": \"#ff716c\",\n                        \"primary-dim\": \"#00deec\",\n                        \"on-tertiary-fixed\": \"#004627\",\n                        \"surface-variant\": \"#25252d\",\n                        \"on-secondary-fixed-variant\": \"#950085\",\n                        \"secondary-fixed\": \"#ffbeeb\",\n                        \"on-secondary-fixed\": \"#640059\",\n                        \"surface-container-lowest\": \"#000000\",\n                        \"on-background\": \"#f9f5fd\",\n                        \"outline\": \"#76747b\",\n                        \"on-primary-container\": \"#005359\",\n                        \"primary-fixed-dim\": \"#00deec\",\n                        \"primary-fixed\": \"#00eefc\",\n                        \"on-tertiary-fixed-variant\": \"#00653b\",\n                        \"on-surface\": \"#f9f5fd\",\n                        \"surface-bright\": \"#2c2b33\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Manrope\"],\n                        \"label\": [\"Space Grotesk\"]\n                    },\n                    borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n                },\n            },\n        }\n    </script>\n<style>\n        .scanline {\n            width: 100%;\n            height: 2px;\n            background: rgba(143, 245, 255, 0.05);\n            position: absolute;\n            z-index: 10;\n        }\n        .digital-grid {\n            background-size: 40px 40px;\n            background-image: \n                linear-gradient(to right, rgba(143, 245, 255, 0.03) 1px, transparent 1px),\n                linear-gradient(to bottom, rgba(143, 245, 255, 0.03) 1px, transparent 1px);\n        }\n        .perspective-grid {\n            perspective: 1000px;\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface font-body text-on-surface overflow-hidden h-screen w-screen relative select-none\">\n<!-- Gameplay Overlay Effects -->\n<div class=\"fixed inset-0 pointer-events-none digital-grid z-0\"></div>\n<div class=\"fixed inset-0 pointer-events-none z-10 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(14,14,19,0.8)_100%)]\"></div>\n<!-- TopAppBar (Shared Component Implementation) -->\n<header class=\"fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 py-4 w-full bg-slate-950/70 backdrop-blur-md border-b border-white/5 shadow-[0_4px_20px_rgba(0,0,0,0.5)]\">\n<div class=\"flex items-center gap-4\">\n<span class=\"text-cyan-400 font-space-grotesk font-bold tracking-tighter uppercase text-2xl font-black drop-shadow-[0_0_8px_rgba(0,240,255,0.8)]\">\n                NEON PULSE\n            </span>\n<div class=\"h-6 w-[2px] bg-outline-variant/30 hidden md:block\"></div>\n<div class=\"flex flex-col\">\n<span class=\"font-headline text-[10px] text-on-surface-variant tracking-[0.2em] uppercase leading-none\">Status</span>\n<span class=\"font-headline text-primary font-bold text-sm\">LVL 12</span>\n</div>\n</div>\n<div class=\"flex items-center gap-8\">\n<div class=\"flex flex-col items-end\">\n<span class=\"font-headline text-[10px] text-on-surface-variant tracking-[0.2em] uppercase leading-none\">Score</span>\n<span class=\"font-headline text-primary font-bold text-lg drop-shadow-[0_0_5px_#8ff5ff]\">000,450</span>\n</div>\n<button class=\"text-cyan-400 hover:text-fuchsia-500 hover:scale-105 transition-all active:scale-95 duration-75\">\n<span class=\"material-symbols-outlined text-3xl\">pause</span>\n</button>\n</div>\n</header>\n<!-- Main Gameplay Area (70% Clear) -->\n<main class=\"relative h-full w-full flex items-center justify-center pointer-events-none\">\n<!-- Visual anchor for the central player ship / focus -->\n<div class=\"w-16 h-16 border-2 border-primary/20 rounded-full flex items-center justify-center\">\n<div class=\"w-2 h-2 bg-primary rounded-full animate-pulse shadow-[0_0_10px_#8ff5ff]\"></div>\n</div>\n<!-- Peripheral Vignette for HUD Focus -->\n<div class=\"absolute inset-x-0 bottom-0 h-1/4 bg-gradient-to-t from-surface to-transparent\"></div>\n</main>\n<!-- Interactive Tactical HUD (Lower Region) -->\n<div class=\"fixed bottom-0 left-0 w-full p-8 z-40 pointer-events-none flex justify-between items-end\">\n<!-- Left Controls: Directionals -->\n<div class=\"flex flex-col gap-2 pointer-events-auto\">\n<div class=\"grid grid-cols-3 gap-2\">\n<div class=\"col-start-2 w-14 h-14 bg-surface-container/40 backdrop-blur-md rounded-md border border-primary/20 flex items-center justify-center text-primary-dim hover:bg-primary/20 active:scale-90 transition-all\">\n<span class=\"material-symbols-outlined text-3xl\">keyboard_arrow_up</span>\n</div>\n<div class=\"col-start-1 row-start-2 w-14 h-14 bg-surface-container/40 backdrop-blur-md rounded-md border border-primary/20 flex items-center justify-center text-primary-dim hover:bg-primary/20 active:scale-90 transition-all\">\n<span class=\"material-symbols-outlined text-3xl\">keyboard_arrow_left</span>\n</div>\n<div class=\"col-start-2 row-start-2 w-14 h-14 bg-surface-container/40 backdrop-blur-md rounded-md border border-primary/20 flex items-center justify-center text-primary-dim hover:bg-primary/20 active:scale-90 transition-all\">\n<span class=\"material-symbols-outlined text-3xl\">keyboard_arrow_down</span>\n</div>\n<div class=\"col-start-3 row-start-2 w-14 h-14 bg-surface-container/40 backdrop-blur-md rounded-md border border-primary/20 flex items-center justify-center text-primary-dim hover:bg-primary/20 active:scale-90 transition-all\">\n<span class=\"material-symbols-outlined text-3xl\">keyboard_arrow_right</span>\n</div>\n</div>\n</div>\n<!-- Center Status: Minimal Indicators -->\n<div class=\"flex flex-col gap-4 items-center w-1/3 mb-4\">\n<div class=\"w-full max-w-xs space-y-2\">\n<div class=\"flex justify-between items-end\">\n<span class=\"font-headline text-[10px] tracking-widest text-secondary font-bold\">SHIELDS</span>\n<span class=\"font-headline text-[10px] text-secondary\">100%</span>\n</div>\n<!-- Pulse Progress Bar Implementation -->\n<div class=\"h-1.5 w-full bg-surface-container-lowest overflow-hidden rounded-full ring-1 ring-secondary/20\">\n<div class=\"h-full bg-gradient-to-r from-secondary to-secondary-dim w-full relative\">\n<div class=\"absolute right-0 top-0 bottom-0 w-4 bg-white/40 blur-sm\"></div>\n</div>\n</div>\n</div>\n<div class=\"w-full max-w-xs space-y-2\">\n<div class=\"flex justify-between items-end\">\n<span class=\"font-headline text-[10px] tracking-widest text-primary font-bold\">ENERGY</span>\n<span class=\"font-headline text-[10px] text-primary\">MAX</span>\n</div>\n<div class=\"h-1.5 w-full bg-surface-container-lowest overflow-hidden rounded-full ring-1 ring-primary/20\">\n<div class=\"h-full bg-gradient-to-r from-primary to-primary-container w-full relative\">\n<div class=\"absolute right-0 top-0 bottom-0 w-8 bg-white/30 blur-sm\"></div>\n</div>\n</div>\n</div>\n</div>\n<!-- Right Controls: Actions -->\n<div class=\"flex flex-col gap-4 items-end pointer-events-auto\">\n<button class=\"w-20 h-20 bg-secondary/10 backdrop-blur-xl rounded-full border-2 border-secondary/40 flex flex-col items-center justify-center text-secondary shadow-[0_0_30px_rgba(255,89,227,0.2)] active:scale-90 transition-transform\">\n<span class=\"material-symbols-outlined text-4xl\" data-weight=\"fill\">bolt</span>\n<span class=\"font-headline text-[10px] font-bold tracking-tighter\">BOOST</span>\n</button>\n<button class=\"px-6 py-2 bg-tertiary-container/10 border border-tertiary/30 rounded-md text-tertiary flex items-center gap-2 active:scale-95 transition-all\">\n<span class=\"material-symbols-outlined text-sm\">target</span>\n<span class=\"font-headline text-[12px] font-bold tracking-widest uppercase\">Target Lock</span>\n</button>\n</div>\n</div>\n<!-- BottomNavBar (Status Bar Variant) -->\n<div class=\"fixed bottom-8 flex gap-8 items-center px-8 py-2 bg-slate-900/40 backdrop-blur-xl rounded-full border border-white/10 z-50 left-1/2 -translate-x-1/2 pointer-events-auto\">\n<div class=\"flex items-center justify-center text-slate-500 p-4 hover:text-fuchsia-400 transition-colors active:scale-90 duration-150 cursor-pointer\">\n<span class=\"material-symbols-outlined\">grid_view</span>\n</div>\n<!-- Active Tab: Gameplay/Action -->\n<div class=\"flex items-center justify-center bg-cyan-400/20 text-cyan-400 rounded-full p-4 ring-1 ring-cyan-400/50 active:scale-90 duration-150 cursor-pointer\">\n<span class=\"material-symbols-outlined\" data-weight=\"fill\">bolt</span>\n</div>\n<div class=\"flex items-center justify-center text-slate-500 p-4 hover:text-fuchsia-400 transition-colors active:scale-90 duration-150 cursor-pointer\">\n<span class=\"material-symbols-outlined\">settings</span>\n</div>\n</div>\n<!-- Ambient HUD Decorative Elements -->\n<div class=\"absolute top-24 left-8 pointer-events-none opacity-40 flex flex-col gap-1\">\n<div class=\"w-32 h-[1px] bg-primary-container\"></div>\n<div class=\"font-headline text-[8px] tracking-[0.5em] text-primary\">SECTOR_B7_ALPHA</div>\n</div>\n<div class=\"absolute top-24 right-8 pointer-events-none opacity-40 flex flex-col items-end gap-1\">\n<div class=\"w-32 h-[1px] bg-secondary\"></div>\n<div class=\"font-headline text-[8px] tracking-[0.5em] text-secondary\">SYNC_ESTABLISHED</div>\n</div>\n</body></html>"}
