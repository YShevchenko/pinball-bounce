{"screenId":"d79c08eb427043d09ed8599c6ba94076","projectId":"6679960351145125367","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0, viewport-fit=cover\" name=\"viewport\"/>\n<title>Neon Pulse - Title Screen</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"error\": \"#ff716c\",\n                        \"inverse-on-surface\": \"#55545b\",\n                        \"outline\": \"#76747b\",\n                        \"on-primary-fixed\": \"#003f43\",\n                        \"primary-fixed\": \"#00eefc\",\n                        \"surface-container-lowest\": \"#000000\",\n                        \"surface-dim\": \"#0e0e13\",\n                        \"tertiary-dim\": \"#00ec90\",\n                        \"primary-fixed-dim\": \"#00deec\",\n                        \"tertiary-fixed-dim\": \"#00ec90\",\n                        \"surface-variant\": \"#25252d\",\n                        \"surface\": \"#0e0e13\",\n                        \"on-error-container\": \"#ffa8a3\",\n                        \"on-secondary-fixed-variant\": \"#950085\",\n                        \"inverse-primary\": \"#006a71\",\n                        \"secondary-fixed-dim\": \"#ffa8e7\",\n                        \"surface-bright\": \"#2c2b33\",\n                        \"error-dim\": \"#d7383b\",\n                        \"on-error\": \"#490006\",\n                        \"on-secondary-fixed\": \"#640059\",\n                        \"secondary-container\": \"#ad009b\",\n                        \"on-primary-fixed-variant\": \"#005e64\",\n                        \"surface-container-highest\": \"#25252d\",\n                        \"on-tertiary\": \"#00643a\",\n                        \"inverse-surface\": \"#fcf8ff\",\n                        \"primary-dim\": \"#00deec\",\n                        \"secondary\": \"#ff59e3\",\n                        \"primary-container\": \"#00eefc\",\n                        \"surface-tint\": \"#8ff5ff\",\n                        \"on-tertiary-fixed\": \"#004627\",\n                        \"primary\": \"#8ff5ff\",\n                        \"on-secondary-container\": \"#fff5f8\",\n                        \"on-surface\": \"#f9f5fd\",\n                        \"outline-variant\": \"#48474d\",\n                        \"on-primary\": \"#005d63\",\n                        \"tertiary\": \"#a1ffc2\",\n                        \"secondary-fixed\": \"#ffbeeb\",\n                        \"surface-container-low\": \"#131319\",\n                        \"on-tertiary-fixed-variant\": \"#00653b\",\n                        \"secondary-dim\": \"#ff59e3\",\n                        \"on-background\": \"#f9f5fd\",\n                        \"tertiary-container\": \"#00fc9a\",\n                        \"surface-container-high\": \"#1f1f26\",\n                        \"tertiary-fixed\": \"#00fc9a\",\n                        \"surface-container\": \"#19191f\",\n                        \"on-tertiary-container\": \"#005b34\",\n                        \"on-primary-container\": \"#005359\",\n                        \"error-container\": \"#9f0519\",\n                        \"background\": \"#0e0e13\",\n                        \"on-surface-variant\": \"#acaab1\",\n                        \"on-secondary\": \"#42003a\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Manrope\"],\n                        \"label\": [\"Space Grotesk\"]\n                    },\n                    borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n                },\n            },\n        }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .neon-grid {\n            background-size: 40px 40px;\n            background-image: \n                linear-gradient(to right, rgba(143, 245, 255, 0.05) 1px, transparent 1px),\n                linear-gradient(to bottom, rgba(143, 245, 255, 0.05) 1px, transparent 1px);\n        }\n        .glow-text-primary {\n            text-shadow: 0 0 10px rgba(143, 245, 255, 0.8), 0 0 20px rgba(143, 245, 255, 0.4);\n        }\n        .glow-text-secondary {\n            text-shadow: 0 0 10px rgba(255, 89, 227, 0.8), 0 0 20px rgba(255, 89, 227, 0.4);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface font-body selection:bg-primary selection:text-on-primary overflow-hidden\">\n<!-- Background Layer -->\n<div class=\"fixed inset-0 z-0\">\n<div class=\"absolute inset-0 neon-grid\"></div>\n<div class=\"absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent\"></div>\n<!-- Distant Glow Orbs -->\n<div class=\"absolute top-[20%] left-[10%] w-64 h-64 bg-primary/10 blur-[120px] rounded-full\"></div>\n<div class=\"absolute bottom-[20%] right-[10%] w-96 h-96 bg-secondary/10 blur-[150px] rounded-full\"></div>\n</div>\n<!-- UI Overlay Shell -->\n<div class=\"relative z-10 h-screen flex flex-col justify-between p-6 pb-safe\">\n<!-- Top Navigation Area (Shared Component Logic - TopAppBar Simplified) -->\n<header class=\"flex justify-between items-start w-full absolute top-0 left-0 px-6 py-8 z-50\">\n<div class=\"flex flex-col\">\n<span class=\"font-label text-[10px] uppercase tracking-[0.2em] text-outline\">CURRENT SEASON</span>\n<div class=\"flex items-baseline gap-3\">\n<h2 class=\"font-headline text-2xl font-bold uppercase tracking-tighter text-on-surface\">HIGH SCORE</h2>\n<span class=\"font-headline text-3xl font-extrabold text-primary glow-text-primary tracking-tighter\">1,248,900</span>\n</div>\n</div>\n<button class=\"w-12 h-12 flex items-center justify-center bg-surface-container-high rounded-full hover:text-fuchsia-500 transition-colors duration-300 active:scale-95\">\n<span class=\"material-symbols-outlined text-outline\" data-icon=\"settings\">settings</span>\n</button>\n</header>\n<!-- Central Play Core -->\n<main class=\"flex-grow flex flex-col items-center justify-center gap-12 pt-20\">\n<!-- Game Branding (Asymmetric Logo Placement) -->\n<div class=\"relative mb-8 text-center\">\n<h1 class=\"font-headline text-[5rem] md:text-[8rem] font-black italic tracking-tighter leading-none text-transparent bg-clip-text bg-gradient-to-br from-primary via-primary-fixed to-secondary drop-shadow-[0_0_30px_rgba(143,245,255,0.4)]\">\n                    NEON<br/>PULSE\n                </h1>\n<div class=\"absolute -bottom-2 -right-4 bg-secondary-container text-on-secondary-container font-label text-[10px] px-2 py-1 uppercase tracking-widest rounded-sm rotate-3\">\n                    BETA 2.0\n                </div>\n</div>\n<!-- Primary Action: Vibrant PLAY Button -->\n<div class=\"relative group\">\n<!-- Outer Glow Aura -->\n<div class=\"absolute inset-0 bg-primary blur-2xl opacity-20 group-hover:opacity-40 transition-opacity duration-500\"></div>\n<button class=\"relative flex flex-col items-center justify-center w-48 h-48 rounded-full bg-gradient-to-br from-primary to-primary-container p-1 shadow-[0_0_50px_rgba(0,238,252,0.4)] transition-transform duration-300 active:scale-90 group-hover:scale-105\">\n<div class=\"w-full h-full bg-background rounded-full flex flex-center items-center justify-center\">\n<span class=\"material-symbols-outlined text-primary text-7xl leading-none glow-text-primary group-hover:text-secondary group-hover:glow-text-secondary transition-all duration-300\" data-icon=\"play_arrow\" style=\"font-variation-settings: 'FILL' 1;\">play_arrow</span>\n</div>\n</button>\n<span class=\"absolute -bottom-8 left-1/2 -translate-x-1/2 font-headline text-lg font-bold uppercase tracking-[0.4em] text-primary group-hover:text-secondary transition-colors\">PLAY</span>\n</div>\n</main>\n<!-- Bottom Stats & Social Bar (Custom Layout mirroring BottomNavBar logic) -->\n<footer class=\"w-full flex justify-between items-end\">\n<!-- Social Interaction Chips -->\n<div class=\"flex gap-4\">\n<div class=\"flex flex-col gap-1\">\n<span class=\"font-label text-[9px] text-outline uppercase tracking-widest\">ACTIVE DRIVERS</span>\n<div class=\"flex -space-x-2\">\n<div class=\"w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center text-[10px] font-bold\">JD</div>\n<div class=\"w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center text-[10px] font-bold\">MK</div>\n<div class=\"w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center text-[10px] font-bold text-primary\">+12k</div>\n</div>\n</div>\n</div>\n<!-- Bottom Icons (Shared Component: BottomNavBar logic) -->\n<div class=\"bg-zinc-950/70 backdrop-blur-xl rounded-full px-8 py-4 flex gap-10 shadow-[0_-8px_32px_rgba(255,89,227,0.1)]\">\n<button class=\"flex flex-col items-center justify-center text-zinc-600 hover:text-cyan-300 transition-transform active:scale-90\">\n<span class=\"material-symbols-outlined text-2xl\" data-icon=\"leaderboard\">leaderboard</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-fuchsia-500 drop-shadow-[0_0_8px_rgba(255,89,227,0.8)] transition-transform active:scale-90\">\n<span class=\"material-symbols-outlined text-2xl\" data-icon=\"play_arrow\" style=\"font-variation-settings: 'FILL' 1;\">play_arrow</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-zinc-600 hover:text-cyan-300 transition-transform active:scale-90\">\n<span class=\"material-symbols-outlined text-2xl\" data-icon=\"emoji_events\">emoji_events</span>\n</button>\n</div>\n<!-- Currency/Level Quick View -->\n<div class=\"text-right\">\n<span class=\"font-label text-[10px] text-outline uppercase tracking-widest\">SYNC STATUS</span>\n<div class=\"flex items-center gap-2\">\n<div class=\"w-2 h-2 rounded-full bg-tertiary shadow-[0_0_8px_#00fc9a]\"></div>\n<span class=\"font-headline font-bold text-sm text-tertiary\">ENCRYPTED</span>\n</div>\n</div>\n</footer>\n</div>\n<!-- Ambient Texture Layer -->\n<div class=\"fixed inset-0 pointer-events-none z-20 mix-blend-overlay opacity-30\">\n<div class=\"w-full h-full\" style=\"background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBVemDJcD5Mxy3vRyrNWxy2HiHa6MuvSuwg1-Sy-Bof_kv7mUOAO17yILiLZMzI9nZsFEfcWIAkf5WWR6QlTs9xgmoiStBvc8rxXeqJgeZOTlpszxq5i6kII4EhNosx_hR1xtVk9028gfA2tW-2SEwk9Gm88zEGbOma0vaQ17KhsMRU2__ufDhysOa2Fx35cPgywifkmOw7mf7rOdVwwASOyXX0sUsitinccDANvG2_GuxPpPDZelOANZFOKQpJOGGFF1z3szP52Hs');\"></div>\n</div>\n<!-- Decorative Image Element -->\n<div class=\"fixed bottom-0 right-0 w-1/3 h-2/3 z-5 opacity-20 pointer-events-none\">\n<img alt=\"Aesthetic Background Element\" class=\"w-full h-full object-cover mix-blend-screen\" data-alt=\"abstract wireframe of a futuristic sports car rendered in glowing cyan and magenta lines with motion blur\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuA7eHawIB2m9tgVdpKDFMXFtSMAIDWrSU9OKRC1a-tcWeYyQWCucLMBFVT-n2CzjzLxjiyIfhxdcQPlHRnyoaCa-TbJGXDROsdfdK5njFZ4GN7k20b5Q--2yUfQJpf36Tl9NTvM2iGvc7Bu1sx9kT5aMl97vvfj3FM5jALbEwLO2CqwSBDo455BkX7X63MwTvVW4LuX9N7MlqEajqnXOxs2kP3MIjkf5au7p55UHB4B21WENGwzRwWDD59k_knhDJSfk-Rm9C2gRdE\"/>\n</div>\n</body></html>"}
